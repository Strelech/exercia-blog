---
import Layout from './Layout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: string;
  category?: string;
  readTime?: string;
}

const { title, description, pubDate, category = 'CRPE', readTime = '5 min' } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('fr-FR', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<Layout title={`${title} | Exercia Blog`} description={description} pubDate={pubDate} isArticle={true}>
  <style>
    .article-hero {
      background: var(--ink);
      padding: 72px 24px 56px;
      text-align: center;
    }
    .article-category {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(15,131,143,0.2); color: var(--teal-light);
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; padding: 5px 12px; border-radius: 20px;
      margin-bottom: 20px;
    }
    .article-title {
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 700; color: white;
      line-height: 1.1; letter-spacing: -0.02em;
      max-width: 720px; margin: 0 auto 20px;
    }
    .article-meta {
      display: flex; align-items: center; justify-content: center; gap: 16px;
      font-size: 0.82rem; color: rgba(255,255,255,0.5);
    }
    .article-meta span { display: flex; align-items: center; gap: 5px; }
    .article-body {
      max-width: 720px; margin: 0 auto;
      padding: 56px 24px 0;
    }
    .article-body :global(h2) {
      font-size: 1.6rem; font-weight: 700;
      color: var(--ink); letter-spacing: -0.02em;
      margin: 48px 0 16px; line-height: 1.2;
    }
    .article-body :global(h3) {
      font-size: 1.15rem; font-weight: 700;
      color: var(--ink); margin: 32px 0 12px;
    }
    .article-body :global(p) {
      font-size: 1rem; color: var(--ink-soft);
      line-height: 1.8; margin-bottom: 18px;
    }
    .article-body :global(ul), .article-body :global(ol) {
      margin: 0 0 18px 20px; color: var(--ink-soft);
    }
    .article-body :global(li) {
      font-size: 1rem; line-height: 1.75; margin-bottom: 6px;
    }
    .article-body :global(strong) { color: var(--ink); font-weight: 700; }
    .article-body :global(hr) {
      border: none; border-top: 1px solid var(--border);
      margin: 40px 0;
    }
    .article-body :global(blockquote) {
      border-left: 3px solid var(--teal);
      padding: 14px 20px; margin: 24px 0;
      background: var(--teal-pale); border-radius: 0 8px 8px 0;
      font-size: 1rem; color: var(--teal-dark); font-style: italic;
    }
    .article-body :global(code) {
      background: var(--teal-pale); color: var(--teal-dark);
      padding: 2px 6px; border-radius: 4px; font-size: 0.9em;
    }
    .cta-block {
      background: var(--teal); border-radius: 16px;
      padding: 36px; text-align: center; margin: 48px 0;
    }
    .cta-block h3 {
      color: white; font-size: 1.3rem; font-weight: 700;
      margin-bottom: 8px;
    }
    .cta-block p {
      color: rgba(255,255,255,0.78); font-size: 0.92rem;
      margin-bottom: 22px;
    }
    .cta-block a {
      display: inline-block;
      background: white; color: var(--teal-dark);
      font-weight: 700; font-size: 0.95rem;
      padding: 13px 28px; border-radius: 10px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
      box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    }
    .cta-block a:hover {
      background: var(--yellow); color: var(--ink);
      transform: translateY(-2px);
    }
    .back-link {
      display: inline-flex; align-items: center; gap: 6px;
      color: var(--teal); text-decoration: none;
      font-size: 0.88rem; font-weight: 600;
      padding: 0 24px; margin-top: 24px;
    }
    .back-link:hover { text-decoration: underline; }
    .practice-block {
      background: var(--teal-pale);
      border-left: 3px solid var(--teal);
      border-radius: 0 10px 10px 0;
      padding: 16px 20px;
      margin: 32px 0;
    }
    .practice-block p {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: var(--teal);
      margin-bottom: 6px !important;
    }
    .practice-block a {
      color: var(--teal-dark);
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
    }
    .practice-block a:hover {
      text-decoration: underline;
    }
  </style>

  <a href="/" class="back-link">← Tous les articles</a>

  <div class="article-hero">
    <div class="article-category">{category}</div>
    <h1 class="article-title">{title}</h1>
    <div class="article-meta">
      <span>📅 {formattedDate}</span>
      <span>·</span>
      <span>⏱ {readTime} de lecture</span>
    </div>
  </div>

  <article class="article-body">
    <slot />
<div class="practice-block">
  <p class="practice-label">Mets en pratique</p>
  <a href="https://exercia.org/exercices/{matiere}" 
     class="practice-link">
    → 5 exercices gratuits sur ce thème, sans inscription
  </a>
</div>
    <div class="cta-block">
      <h3>Entraîne-toi sur les épreuves du CRPE</h3>
      <p>20 minutes par jour · Exercices ciblés · Adapté à tes lacunes</p>
      <a href="https://exercia.org/auth?mode=signup">Commencer gratuitement →</a>
    </div>
  </article>
</Layout>
